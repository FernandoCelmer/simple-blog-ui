{
  "name": "simple-blog-ui",
  "version": "0.1.0",
  "description": "Framework-agnostic UI components for simple-blog (works with plain HTML, React, and Vue).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./style.css": "./src/styles/main.css",
    "./tokens.css": "./src/styles/root.css"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "scripts": {
    "build": "vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "ui",
    "web-components",
    "lit",
    "react",
    "vue",
    "simple-blog"
  ],
  "author": "Fernando Celmer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FernandoCelmer/simple-blog-ui.git"
  },
  "dependencies": {
    "@lit/react": "^1.0.6",
    "highlight.js": "^11.10.0",
    "lit": "^3.2.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.3.5",
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/addon-links": "^8.3.5",
    "@storybook/blocks": "^8.3.5",
    "@storybook/web-components": "^8.3.5",
    "@storybook/web-components-vite": "^8.3.5",
    "storybook": "^8.3.5",
    "vite": "^5.4.8"
  }
}
